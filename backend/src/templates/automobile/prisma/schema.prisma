model Category {
  id String @id @default(cuid())
  name String
  slug String @unique
  listings_category Listing[] @relation("Rel_listings_category")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("categories")
}

model Listing {
  id String @id @default(cuid())
