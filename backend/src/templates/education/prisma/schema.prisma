// Generated by synth-next-template.mjs from db_schema.json
// Do not edit by hand; re-run the generator to refresh.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  role String?
  phone String?
  address String?
  enrollments_user Enrollment[] @relation("Rel_enrollments_user")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("users")
}

model Category {
  id String @id @default(cuid())
  name String
  slug String @unique
  courses_category Cours[] @relation("Rel_courses_category")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("categories")
}

model Cours {
  id String @id @default(cuid())
  name String
  slug String @unique
  instructor String?
  duration String?
  price Float?
  description String?
  image String?
  status String
  categoryId String?
  category Category? @relation("Rel_courses_category", fields: [categoryId], references: [id])
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("courses")
}

model Enrollment {
  id String @id @default(cuid())
  userId String
  user User @relation("Rel_enrollments_user", fields: [userId], references: [id])
  course String
  status String
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("enrollments")
}

model Setting {
  id String @id @default(cuid())
  name String
  tagline String?
  currency String
  supportEmail String?
  footerText String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("settings")
}
