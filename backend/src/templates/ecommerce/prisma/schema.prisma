// Generated by synth-next-template.mjs from db_schema.json
// Do not edit by hand; re-run the generator to refresh.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  role String?
  phone String?
  address String?
  orders_user Order[] @relation("Rel_orders_user")
  reviews_user Review[] @relation("Rel_reviews_user")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("users")
}

model Category {
  id String @id @default(cuid())
  name String
  slug String @unique
  image String?
  products_category Product[] @relation("Rel_products_category")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("categories")
}

model Product {
  id String @id @default(cuid())
  name String
  slug String @unique
  price Float
  stock Int
  description String?
  images String?
  categoryId String?
  category Category? @relation("Rel_products_category", fields: [categoryId], references: [id])
  status String
  order_items_product OrderItem[] @relation("Rel_order_items_product")
  reviews_product Review[] @relation("Rel_reviews_product")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("products")
}

model Order {
  id String @id @default(cuid())
  userId String
  user User @relation("Rel_orders_user", fields: [userId], references: [id])
  status String
  total Float
  stripe_payment_intent_id String?
  items String
  order_items_order OrderItem[] @relation("Rel_order_items_order")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("orders")
}

model OrderItem {
  id String @id @default(cuid())
  orderId String
  order Order @relation("Rel_order_items_order", fields: [orderId], references: [id])
  productId String
  product Product @relation("Rel_order_items_product", fields: [productId], references: [id])
  qty Int
  price Float
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("order_items")
}

model Review {
  id String @id @default(cuid())
  productId String
  product Product @relation("Rel_reviews_product", fields: [productId], references: [id])
  userId String
  user User @relation("Rel_reviews_user", fields: [userId], references: [id])
  rating Int
  comment String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("reviews")
}

model Setting {
  id String @id @default(cuid())
  name String
  tagline String?
  currency String
  supportEmail String?
  footerText String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("settings")
}
