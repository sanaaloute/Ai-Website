generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  role String?
  phone String?
  address String?
  bookings_user Booking[] @relation("Rel_bookings_user")
