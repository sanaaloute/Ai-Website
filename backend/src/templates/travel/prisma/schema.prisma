  updated DateTime @updatedAt
  @@map("users")
}

model Category {
  id String @id @default(cuid())
  name String
  slug String @unique
  tours_category Tour[] @relation("Rel_tours_category")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("categories")
}

model Tour {
  id String @id @default(cuid())
  name String
