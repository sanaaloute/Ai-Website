  tourId String?
  tour Tour? @relation("Rel_bookings_tour", fields: [tourId], references: [id])
  status String
  notes String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("bookings")
}

model Setting {
  id String @id @default(cuid())
