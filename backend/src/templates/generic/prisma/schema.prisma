// Generated by synth-next-template.mjs from db_schema.json
// Do not edit by hand; re-run the generator to refresh.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  role String?
  phone String?
  address String?
  contacts_user Contact[] @relation("Rel_contacts_user")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("users")
}

model Page {
  id String @id @default(cuid())
  title String
  slug String @unique
  content String?
  status String
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("pages")
}

model Contact {
  id String @id @default(cuid())
  userId String?
  user User? @relation("Rel_contacts_user", fields: [userId], references: [id])
  name String
  email String
  message String
  status String
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("contacts")
}

model Setting {
  id String @id @default(cuid())
  name String
  tagline String?
  footerText String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("settings")
}
