# ─── AI Gateway ─────────────────────────────────────────────────────
AI_BASE_URL=https://api.gitcc.com/v1
AI_API_KEY=
AI_DEFAULT_MODEL=gpt-5.4
AI_REFLECTION_MODEL=qwen-max

# ─── Sandbox ────────────────────────────────────────────────────────
E2B_API_KEY=e2b_...
SANDBOX_PROVIDER=e2b
PROJECTS_DB_PATH=./data/projects.db
# Directory where the agent persists project file snapshots.
# In Docker, ensure this path is writable by the container user.
AGENT_STORE_DIR=./.agent_store

# ─── Database (Prisma/Postgres) ─────────────────────────────────────
# Platform database connection. The self-host compose sets this to the bundled
# postgres service; for local dev point it at your own Postgres.
DATABASE_URL=postgresql://lovecode:lovecode@localhost:5432/lovecode?schema=public

# ─── Supabase ───────────────────────────────────────────────────────
# Aliases accepted: NEXT_PUBLIC_SUPABASE_URL ↔ SUPABASE_URL, etc.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Redis (required: queues, rate limits, sandbox state, sessions) ─
REDIS_URL=redis://localhost:6379/0

# ─── Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_BASIC_ONETIME=
STRIPE_PRICE_BASIC_ONE_TIME=
STRIPE_PRICE_STANDARD_MONTHLY=price_...
STRIPE_PRICE_STANDARD_YEARLY=price_...
STRIPE_PRICE_STANDARD_ONETIME=
STRIPE_PRICE_STANDARD_ONE_TIME=
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_PRO_ONETIME=
STRIPE_PRICE_PRO_ONE_TIME=

# ─── GitHub OAuth (repository push) ─────────────────────────────────
# Create a GitHub OAuth App and use its client id/secret. The callback URL
# must match the App's "Authorization callback URL".
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/github/callback
GITHUB_COOKIE_DOMAIN=localhost

# ─── Vercel (deployment) ────────────────────────────────────────────
# A Vercel personal/team access token. VERCEL_TEAM_ID is optional (only needed
# when deploying into a team rather than the personal account).
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_DEFAULT_DOMAIN=vercel.app

# ─── Deploy provider (self-host) ────────────────────────────────────
# vercel = managed Vercel (default). docker = same-server Docker + Traefik.
# coolify = delegate to a sibling Coolify. See SELFHOST.md.
DEPLOY_PROVIDER=vercel
DEPLOY_BASE_DOMAIN=localhost
DEPLOY_WORKSPACE_DIR=/var/lib/lovecode/sites
SITE_NETWORK=lovecode_web
SITE_CPU_LIMIT=1.0
SITE_MEMORY_LIMIT=512m
SITE_BUILD_TIMEOUT_SECONDS=600
DOCKER_SOCKET=/var/run/docker.sock
# Only when DEPLOY_PROVIDER=coolify:
COOLIFY_URL=
COOLIFY_TOKEN=

# ─── Optional Fast Apply / Reflection ───────────────────────────────
MORPH_API_KEY=

# ─── Admin auth ─────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRY_MINUTES=1440
ADMIN_REGISTRATION_SECRET=

# AES-256-GCM key for encrypting third-party integration tokens.
# Should be a 32-byte value (base64, hex, or plain string). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# ─── App / runtime ──────────────────────────────────────────────────
NODE_ENV=development
APP_HOST=0.0.0.0
PORT=4000
APP_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
SITE_URL=http://localhost:3000
# Production example (lovecode.com served through nginx):
# FRONTEND_ORIGIN=https://lovecode.com,https://www.lovecode.com
# APP_URL=https://lovecode.com
# NEXT_PUBLIC_APP_URL=https://lovecode.com
# SITE_URL=https://lovecode.com
LOG_LEVEL=INFO

# ─── Session cookies (httpOnly) ─────────────────────────────────────
ACCESS_TOKEN_COOKIE_NAME=lc_access_token
REFRESH_TOKEN_COOKIE_NAME=lc_refresh_token
ADMIN_TOKEN_COOKIE_NAME=lc_admin_token

# Production: set COOKIE_DOMAIN to the shared parent domain if the API and
# frontend live on different subdomains (e.g. app.lovecode.com + api.lovecode.com).
# For the bundled nginx setup (lovecode.com/api), leave COOKIE_DOMAIN unset.
# COOKIE_DOMAIN=.lovecode.com

# lax is fine when frontend and API share the same origin. Use 'none' only for
# cross-subdomain API calls, and pair it with COOKIE_SECURE=true.
COOKIE_SAME_SITE=lax

# The backend now auto-detects HTTPS from X-Forwarded-Proto and marks cookies
# Secure when this is left unset. Explicitly set it to 'true' for production or
# 'false' to force non-Secure cookies (not recommended on HTTPS).
COOKIE_SECURE=false

# ─── LoveCode API key acquisition URL ───────────────────────────────
LOVECODE_API_KEY_SITE_URL=https://api.gitcc.com/dashboard/overview
NEXT_PUBLIC_LOVECODE_API_KEY_SITE_URL=https://api.gitcc.com/dashboard/overview

# ─── Agent documentation MCP server (optional) ──────────────────────
# CONTEXT7_API_KEY enables authenticated Context7 doc lookups.
# MCP_DOCS_ENABLED defaults to true; set to false to disable doc tools.
# MCP_DOCS_CACHE_TTL_SECONDS defaults to 3600.
CONTEXT7_API_KEY=
MCP_DOCS_ENABLED=true
MCP_DOCS_CACHE_TTL_SECONDS=3600
