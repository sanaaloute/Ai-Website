# ─── AI Gateway ─────────────────────────────────────────────────────
AI_BASE_URL=https://www.tokenfree.com/v1
AI_API_KEY=
# NEW_API_KEY is accepted as a legacy alias for AI_API_KEY.
AI_DEFAULT_MODEL=qwen-max
# Base URL of the built-in TokenFree provider (defaults to AI_BASE_URL):
# TOKENFREE_BASE_URL=https://www.tokenfree.com/v1
# Optional per-provider base URL overrides (users pick the provider and supply
# their own API key in their profile; defaults are used when unset):
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
# KIE_AI_BASE_URL=https://api.kie.ai/api/v1
# Models the agent runtime may use (comma-separated) and the primary model per
# agent role (each role primary must also be listed in AI_ALLOWED_MODELS):
# AI_ALLOWED_MODELS=kimi-k2.5,qwen-max
# AI_MODEL_REASONING=kimi-k2.5
# AI_MODEL_CODE=kimi-k2.5
# AI_MODEL_REVIEW=kimi-k2.5
# AI_MODEL_FAST=qwen-max
# Sampling temperature per agent role (0.0–1.0) and an optional global
# max_tokens cap for LLM responses:
# AI_TEMP_REASONING=0.3
# AI_TEMP_CODE=0.3
# AI_TEMP_REVIEW=0.2
# AI_TEMP_FAST=0.7
# AI_MAX_TOKENS=
# Streaming LLM call watchdogs: abort when no SSE chunk arrives within the idle
# window, and a hard ceiling for one streaming call (both in milliseconds):
# AI_STREAM_IDLE_TIMEOUT_MS=120000
# AI_STREAM_TOTAL_TIMEOUT_MS=1200000
# Hard ceiling for one agent generation job in the queue (milliseconds):
# AGENT_JOB_TIMEOUT_MS=1800000
# Agent workflow tuning:
# AGENT_MAX_NODE_ATTEMPTS=3          # retries per failed graph node
# AGENT_RECURSION_LIMIT=50           # LangGraph recursion limit per run
# AGENT_WORKER_CONCURRENCY=4         # BullMQ worker slots
# AGENT_MAX_CONCURRENT_GENERATIONS=2 # per-user active generations
# AGENT_MAX_ENQUEUES_PER_MINUTE=10   # per-user enqueue rate

# ─── Sandbox ────────────────────────────────────────────────────────
E2B_API_KEY=e2b_...
# Directory where the agent persists project file snapshots.
# In Docker, ensure this path is writable by the container user.
AGENT_STORE_DIR=./.agent_store
# Docker socket used by the site deployment runner (self-hosted deploys):
# DOCKER_HOST=unix:///var/run/docker.sock

# ─── Database (Prisma/Postgres) ─────────────────────────────────────
# Platform database connection. The self-host compose sets this to the bundled
# postgres service; for local dev point it at your own Postgres.
DATABASE_URL=postgresql://lovecode:lovecode@localhost:5432/lovecode?schema=public

# ─── Supabase ───────────────────────────────────────────────────────
# Aliases accepted: NEXT_PUBLIC_SUPABASE_URL ↔ SUPABASE_URL, etc.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Redis (required: queues, rate limits, sandbox state, sessions) ─
REDIS_URL=redis://localhost:6379/0

# ─── Paddle ─────────────────────────────────────────────────────────
PADDLE_API_KEY=live_...
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_BASIC_MONTHLY=pri_...
PADDLE_PRICE_BASIC_YEARLY=pri_...
PADDLE_PRICE_BASIC_ONETIME=
PADDLE_PRICE_BASIC_ONE_TIME=
PADDLE_PRICE_STANDARD_MONTHLY=pri_...
PADDLE_PRICE_STANDARD_YEARLY=pri_...
PADDLE_PRICE_STANDARD_ONETIME=
PADDLE_PRICE_STANDARD_ONE_TIME=
PADDLE_PRICE_PRO_MONTHLY=pri_...
PADDLE_PRICE_PRO_YEARLY=pri_...
PADDLE_PRICE_PRO_ONETIME=
PADDLE_PRICE_PRO_ONE_TIME=

# ─── GitHub OAuth (repository push) ─────────────────────────────────
# Create a GitHub OAuth App and use its client id/secret. The callback URL
# must match the App's "Authorization callback URL".
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/github/callback
GITHUB_COOKIE_DOMAIN=localhost

# ─── Template marketplace ───────────────────────────────────────────
# GitHub repo hosting the templates/ directory, as "owner/repo". Used to
# download a single template subdirectory without cloning the whole repo.
# Leave empty while developing locally (the local templates/ dir is used).
TEMPLATE_REPO=
TEMPLATE_REPO_REF=main
# Optional: token for private repos / higher GitHub rate limits.
GITHUB_TOKEN=
# Optional: absolute path override for the local templates directory.
# TEMPLATES_DIR=

# ─── Vercel (deployment) ────────────────────────────────────────────
# A Vercel personal/team access token. VERCEL_TEAM_ID is optional (only needed
# when deploying into a team rather than the personal account).
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_DEFAULT_DOMAIN=vercel.app

# ─── Deploy provider (self-host) ────────────────────────────────────
# vercel = managed Vercel (default). docker = same-server Docker + Traefik.
# coolify = delegate to a sibling Coolify. See SELFHOST.md.
DEPLOY_PROVIDER=vercel
DEPLOY_BASE_DOMAIN=localhost
DEPLOY_WORKSPACE_DIR=/var/lib/ai-website/sites
SITE_NETWORK=aiwebsite_web
SITE_CPU_LIMIT=1.0
SITE_MEMORY_LIMIT=512m
SITE_BUILD_TIMEOUT_SECONDS=600
DOCKER_SOCKET=/var/run/docker.sock
# Only when DEPLOY_PROVIDER=coolify:
COOLIFY_URL=
COOLIFY_TOKEN=

# ─── Optional Fast Apply / Reflection ───────────────────────────────
MORPH_API_KEY=

# ─── Admin auth ─────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRY_MINUTES=1440
ADMIN_REGISTRATION_SECRET=

# AES-256-GCM key for encrypting third-party integration tokens.
# Should be a 32-byte value (base64, hex, or plain string). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# ─── App / runtime ──────────────────────────────────────────────────
NODE_ENV=development
APP_HOST=0.0.0.0
PORT=4000
APP_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001
# CORS_ORIGINS is accepted as a legacy alias for FRONTEND_ORIGIN.
CORS_CREDENTIALS=true
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
SITE_URL=http://localhost:3000
# Production example (ai-web-builder.com served through nginx):
# FRONTEND_ORIGIN=https://ai-web-builder.com,https://www.ai-web-builder.com,https://admin.ai-web-builder.com
# APP_URL=https://ai-web-builder.com
# NEXT_PUBLIC_APP_URL=https://ai-web-builder.com
# SITE_URL=https://ai-web-builder.com
LOG_LEVEL=INFO

# ─── Session cookies (httpOnly) ─────────────────────────────────────
ACCESS_TOKEN_COOKIE_NAME=lc_access_token
REFRESH_TOKEN_COOKIE_NAME=lc_refresh_token
ADMIN_TOKEN_COOKIE_NAME=lc_admin_token

# Production: set COOKIE_DOMAIN to the shared parent domain if the API and
# frontend live on different subdomains (e.g. app.ai-web-builder.com + api.ai-web-builder.com).
# For the bundled nginx setup (ai-web-builder.com/api), leave COOKIE_DOMAIN unset.
# COOKIE_DOMAIN=.ai-web-builder.com

# lax is fine when frontend and API share the same origin. Use 'none' only for
# cross-subdomain API calls, and pair it with COOKIE_SECURE=true.
COOKIE_SAME_SITE=lax

# The backend now auto-detects HTTPS from X-Forwarded-Proto and marks cookies
# Secure when this is left unset. Explicitly set it to 'true' for production or
# 'false' to force non-Secure cookies (not recommended on HTTPS).
COOKIE_SECURE=false

# ─── LoveCode API key acquisition URL ───────────────────────────────
AI_WEBSITE_API_KEY_SITE_URL=https://www.tokenfree.com
NEXT_PUBLIC_AI_WEBSITE_API_KEY_SITE_URL=https://www.tokenfree.com

# ─── Agent documentation MCP server (optional) ──────────────────────
# CONTEXT7_API_KEY enables authenticated Context7 doc lookups.
# MCP_DOCS_ENABLED defaults to true; set to false to disable doc tools.
# MCP_DOCS_CACHE_TTL_SECONDS defaults to 3600.
CONTEXT7_API_KEY=
MCP_DOCS_ENABLED=true
MCP_DOCS_CACHE_TTL_SECONDS=3600
