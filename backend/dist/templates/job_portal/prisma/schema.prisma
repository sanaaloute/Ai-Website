// Generated by synth-next-template.mjs from db_schema.json
// Do not edit by hand; re-run the generator to refresh.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  role String?
  phone String?
  address String?
  applications_user Application[] @relation("Rel_applications_user")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("users")
}

model Category {
  id String @id @default(cuid())
  name String
  slug String @unique
  jobs_category Job[] @relation("Rel_jobs_category")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("categories")
}

model Job {
  id String @id @default(cuid())
  title String
  slug String @unique
  company String?
  location String?
  salary String?
  description String?
  status String
  categoryId String?
  category Category? @relation("Rel_jobs_category", fields: [categoryId], references: [id])
  applications_job Application[] @relation("Rel_applications_job")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("jobs")
}

model Application {
  id String @id @default(cuid())
  userId String
  user User @relation("Rel_applications_user", fields: [userId], references: [id])
  jobId String
  job Job @relation("Rel_applications_job", fields: [jobId], references: [id])
  status String
  coverLetter String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("applications")
}

model Setting {
  id String @id @default(cuid())
  name String
  tagline String?
  supportEmail String?
  footerText String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("settings")
}
