// Generated by synth-next-template.mjs from db_schema.json
// Do not edit by hand; re-run the generator to refresh.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  role String?
  phone String?
  address String?
  subscribers_user Subscriber[] @relation("Rel_subscribers_user")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("users")
}

model Plan {
  id String @id @default(cuid())
  name String
  slug String @unique
  price Float?
  subscribers_plan Subscriber[] @relation("Rel_subscribers_plan")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("plans")
}

model Feature {
  id String @id @default(cuid())
  name String
  slug String @unique
  description String?
  icon String?
  status String
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("features")
}

model Subscriber {
  id String @id @default(cuid())
  userId String?
  user User? @relation("Rel_subscribers_user", fields: [userId], references: [id])
  email String
  planId String?
  plan Plan? @relation("Rel_subscribers_plan", fields: [planId], references: [id])
  status String
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("subscribers")
}

model Setting {
  id String @id @default(cuid())
  name String
  tagline String?
  footerText String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("settings")
}
