// Generated by synth-next-template.mjs from db_schema.json
// Do not edit by hand; re-run the generator to refresh.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  role String?
  phone String?
  address String?
  orders_user Order[] @relation("Rel_orders_user")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("users")
}

model Category {
  id String @id @default(cuid())
  name String
  slug String @unique
  products_category Product[] @relation("Rel_products_category")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("categories")
}

model Product {
  id String @id @default(cuid())
  name String
  slug String @unique
  price Float
  stock Int
  description String?
  image String?
  status String
  categoryId String?
  category Category? @relation("Rel_products_category", fields: [categoryId], references: [id])
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("products")
}

model Order {
  id String @id @default(cuid())
  userId String
  user User @relation("Rel_orders_user", fields: [userId], references: [id])
  status String
  total Float
  items String
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("orders")
}

model Setting {
  id String @id @default(cuid())
  name String
  tagline String?
  footerText String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("settings")
}
