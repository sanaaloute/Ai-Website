// Generated by synth-next-template.mjs from db_schema.json
// Do not edit by hand; re-run the generator to refresh.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  role String?
  phone String?
  address String?
  comments_user Comment[] @relation("Rel_comments_user")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("users")
}

model Category {
  id String @id @default(cuid())
  name String
  slug String @unique
  posts_category Post[] @relation("Rel_posts_category")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("categories")
}

model Post {
  id String @id @default(cuid())
  title String
  slug String @unique
  excerpt String?
  content String?
  image String?
  status String
  categoryId String?
  category Category? @relation("Rel_posts_category", fields: [categoryId], references: [id])
  comments_post Comment[] @relation("Rel_comments_post")
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("posts")
}

model Comment {
  id String @id @default(cuid())
  userId String
  user User @relation("Rel_comments_user", fields: [userId], references: [id])
  postId String
  post Post @relation("Rel_comments_post", fields: [postId], references: [id])
  body String
  status String
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("comments")
}

model Setting {
  id String @id @default(cuid())
  name String
  tagline String?
  currency String
  supportEmail String?
  footerText String?
  created DateTime @default(now())
  updated DateTime @updatedAt
  @@map("settings")
}
