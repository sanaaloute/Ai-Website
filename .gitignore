# ============================================
# Root .gitignore for lovecode-project monorepo
# Covers: frontend (Next.js), backend (NestJS), admin (Next.js)
# ============================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js / React build output ---
.next/
out/
build/
next-env.d.ts
*.tsbuildinfo

# --- Python / FastAPI ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/develop-eggs/
backend/downloads/
backend/eggs/
backend/.eggs/
backend/lib/
backend/lib64/
backend/parts/
backend/sdist/
backend/var/
backend/wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Testing / Coverage ---
coverage/
.pytest_cache/
.coverage
htmlcov/

# --- Alembic ---
backend/alembic/versions/*.py
!backend/alembic/versions/__init__.py

# --- Environment variables ---
.env
.env.local
.env.*.local
.env.*.production
.env.*.development

# --- Debug / Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS files ---
.DS_Store
Thumbs.db

# --- Misc ---
*.pem

# --- Playwright MCP runtime logs ---
.playwright-mcp/

# NestJS build output
backend-nestjs/dist/
