# .env.selfhost.example — copy to .env for `docker-compose.selfhost.yml`.
# These are the values specific to self-hosting. The backend still reads the
# rest of its config (LLM keys, OAuth, etc.) from this same .env — see
# backend/.env.example for the full list.

# --- Domain & TLS -----------------------------------------------------------
# Apex domain you own. Platform runs at https://<domain>, API at api.<domain>,
# admin at admin.<domain>, and every user site at <slug>.<domain>.
DEPLOY_BASE_DOMAIN=example.com
# Email used for Let's Encrypt expiry notices.
ACME_EMAIL=admin@example.com

# --- Deploy provider --------------------------------------------------------
# docker  = backend builds/runs each site as a sibling container (single host).
# coolify = delegate to the profile-gated Coolify service (multi-container apps).
DEPLOY_PROVIDER=docker
# Build workspace. MUST be a real host path; it is bind-mounted into the backend
# at the same absolute path so the host docker daemon can build from it.
DEPLOY_WORKSPACE_DIR=/var/lib/lovecode/sites

# --- Platform Postgres ------------------------------------------------------
POSTGRES_USER=lovecode
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lovecode

# --- Coolify (only when DEPLOY_PROVIDER=coolify) ----------------------------
# COOLIFY_URL=http://coolify:8000
# COOLIFY_TOKEN=
